{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "StudyFlow Web App",
  "extends": "../../packages/config/tsconfig/web.json",
  "compilerOptions": {
    "allowJs": false,
    "module": "ESNext",
    "moduleResolution": "Bundler",

    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    },

    "plugins": [
      {
        "name": "next"
      }
    ],
    "types": [
      "node"
    ]
  },
  "include": [
    "next-env.d.ts",
    "next.config.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}